# ─────────────────────────────────────────────────────────────────
# Freight Payroll Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Database — for local dev use Supabase connection string (Transaction mode, port 6543)
# Get from: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_64_byte_hex_secret_here
JWT_REFRESH_SECRET=generate_a_different_64_byte_hex_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for TFN, bank account numbers (32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_32_byte_hex_encryption_key

# Application
PORT=3001
NODE_ENV=development
# For local dev use http://localhost:5173 — for production use your Vercel URL
FRONTEND_URL=http://localhost:5173

# File storage — use local filesystem for dev, S3 for production
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2
# AWS_S3_BUCKET=

# Email (stub for now — set up SendGrid or SES in production)
EMAIL_DRIVER=console
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@yourcompany.com.au

# SMS (stub for now — set up Twilio in production)
SMS_DRIVER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Logging
LOG_LEVEL=debug
