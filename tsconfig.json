{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@freight-payroll/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["api/**/*", "packages/backend/src/**/*", "packages/shared/src/**/*"],
  "exclude": ["node_modules", "packages/frontend"]
}
