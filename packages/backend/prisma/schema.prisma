  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  payRunItemId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([logDate])
  @@index([status])
  @@map("km_logs")
}

// ═══════════════════════════════════════════════════════════════════
// EXPENSE CLAIMS
// ═══════════════════════════════════════════════════════════════════

model ExpenseClaim {
