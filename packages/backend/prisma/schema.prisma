  SALARY
  PER_KM
  PER_LOAD
  PERCENTAGE_REVENUE
  MIXED
}

enum AwardCode {
  MA000038
  MA000039
}

enum AwardClassificationLevel {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  GRADE_7
