// ═══════════════════════════════════════════════════════════════════
// EMPLOYEE ONBOARDING
// ═══════════════════════════════════════════════════════════════════

model EmployeeOnboarding {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Set once the employee record is created on completion
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  inviteEmail String
  // Secure random token used in the invite URL
  token       String   @unique
  expiresAt   DateTime

  status      OnboardingStatus @default(INVITED)
  completedAt DateTime?

  // JSON snapshot of data the employee entered during onboarding
  // (preserved even after employee record is created)
  onboardingData Json?

  invitedBy String // userId of the admin who sent the invite

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([token])
  @@map("employee_onboardings")
}

enum OnboardingStatus {
  INVITED
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  EXPIRED
}
