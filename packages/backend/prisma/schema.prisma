generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════
// ORGANISATIONAL STRUCTURE
// ═══════════════════════════════════════════════════════════════════

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique

  // Billing contact (separate from admin user)
  billingEmail String?
  billingName  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companies    Company[]
  users        User[]
  subscription OrganizationSubscription?
  apiKeys      ApiKey[]
  webhooks     WebhookEndpoint[]
  integrations IntegrationToken[]

  @@map("organizations")
}

model Company {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  tradingName String?
  abn         String  @unique
  acn         String?

  // Branding
  logoKey  String? // S3 key for company logo (used on payslips, portal)

  // Localisation
  timeZone String @default("Australia/Sydney")

  // Payroll settings
  payrollContactName  String?
  payrollContactEmail String?
  payrollContactPhone String?

  // Bank details for ABA payment files (stored encrypted)
  bankBsb          String? // encrypted
  bankAccount      String? // encrypted
  bankAccountName  String?
  bankAbbreviation String? // 3-char bank abbreviation for ABA
  bankUserId       String? // 6-char user ID from bank for ABA

  // STP Phase 2
  stpSoftwareId   String?
  stpBranchNumber Int     @default(1)

  // Address
  addressStreet   String?
  addressSuburb   String?
  addressState    AustralianState?
  addressPostcode String?

  // Workers compensation
  workCoverPolicyNumber String?
  workCoverInsurer      String?

  // Payroll tax (state-level)
  payrollTaxRegistered Boolean          @default(false)
  payrollTaxState      AustralianState?

  defaultPayFrequency PayFrequency @default(WEEKLY)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  depots                Depot[]
  employees             Employee[]
  payRuns               PayRun[]
  allowanceTypes        AllowanceType[]
  deductionTypes        DeductionType[]
  userAccess            UserCompanyAccess[]
  rosters               Roster[]
  vehicles              Vehicle[]
  subcontractors        Subcontractor[]
  enterpriseAgreements  EnterpriseAgreement[]
  expenseClaims         ExpenseClaim[]
  workplaceIncidents    WorkplaceIncident[]
  onboardings           EmployeeOnboarding[]

  @@index([organizationId])
  @@map("companies")
}

model Depot {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String
  code String

  addressStreet   String?
  addressSuburb   String?
  addressState    AustralianState?
  addressPostcode String?

  managerId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("depots")
}

// ═══════════════════════════════════════════════════════════════════
// USERS AND AUTHENTICATION
// ═══════════════════════════════════════════════════════════════════

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String

  globalRole GlobalRole @default(ORG_USER)
  isActive   Boolean    @default(true)

  // Link to an employee record for self-service portal users
  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  // MFA (future)
  mfaEnabled  Boolean @default(false)
  mfaSecret   String? // encrypted TOTP secret

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  refreshTokens RefreshToken[]
  companyAccess UserCompanyAccess[]
  oauthAccounts OAuthAccount[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model UserCompanyAccess {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  role         CompanyRole
  depotId      String? // null = access to all depots in this company
  enabledPages String[]    // empty = role defaults; non-empty = only these pages shown

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_company_access")
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String   // 'google' | 'microsoft'
  providerAccountId String
  email             String?

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════════
// EMPLOYEES
// ═══════════════════════════════════════════════════════════════════

model Employee {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  depotId   String?
  depot     Depot?   @relation(fields: [depotId], references: [id])

  employeeNumber String

  // Personal
  firstName     String
  middleName    String?
  lastName      String
  preferredName String?
  dateOfBirth   DateTime?
  gender        String?

  // Contact
  email  String?
  phone  String?
  mobile String?

  // Address
  addressStreet   String?
  addressSuburb   String?
  addressState    AustralianState?
  addressPostcode String?
  addressCountry  String          @default("AU")

  // Role and employment
  position       String?        // job title / position description
  employmentType EmploymentType
  startDate      DateTime
  endDate        DateTime? // termination date
  terminationReason String?

  // Probation and notice
  probationEndDate  DateTime?
  noticePeriodWeeks Int?

  // Award / classification
  awardCode             AwardCode?
  enterpriseAgreementId String? // FK to EnterpriseAgreement

  // Pay settings
  payFrequency PayFrequency

  // Tax — sensitive fields stored encrypted (AES-256-GCM)
  taxFileNumber          String? // encrypted
  taxResidencyStatus     TaxResidencyStatus @default(RESIDENT)
  claimsTaxFreeThreshold Boolean            @default(true)
  hasHECSDebt            Boolean            @default(false)
  hasSFSSDebt            Boolean            @default(false)
  taxDeclarationDate     DateTime?

  // Superannuation
  superFundName     String?
  superFundAbn      String?
  superMemberNumber String?
  superFundUsi      String?

  // Workers compensation
  workCoverClassCode String?

  // Onboarding
  inductionCompletedAt DateTime?

  // State of employment (may differ from residential address — drives public holiday schedule)
  stateOfEmployment AustralianState?

  // Agreed ordinary hours per week (part-timers / salary employees)
  ordinaryHoursPerWeek Decimal? @db.Decimal(4, 2)

  // Reporting line
  reportsToId String?
  reportsTo   Employee? @relation("ReportsTo", fields: [reportsToId], references: [id])

  // Status
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  user                 User?
  payRates             EmployeePayRate[]
  awardClassifications EmployeeAwardClassification[]
  bankAccounts         BankAccount[]
  emergencyContacts    EmergencyContact[]
  documents            EmployeeDocument[]
  timesheets           Timesheet[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  rosterShifts         RosterShift[]
  licences             DriverLicence[]
  accreditations       Accreditation[]
  medicalCerts         MedicalCertificate[]
  fatigueRecords       FatigueRecord[]
  payRunItems          PayRunItem[]
  kmLogs               KmLog[]
  expenseClaims        ExpenseClaim[]
  workersCompClaims    WorkersCompClaim[]
  workplaceIncidents   WorkplaceIncident[] @relation("IncidentInvolvedEmployee")
  auditLogs            AuditLog[]          @relation("EmployeeAuditLogs")
  subordinates         Employee[]          @relation("ReportsTo")
  availabilities       EmployeeAvailability[]
  trainingRecords      TrainingRecord[]
  onboardings          EmployeeOnboarding[]

  @@unique([companyId, employeeNumber])
  @@index([companyId])
  @@index([depotId])
  @@index([isActive])
  @@map("employees")
}

model EmployeePayRate {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  effectiveFrom DateTime
  effectiveTo   DateTime?

  payType PayType

  hourlyRate        Decimal? @db.Decimal(10, 4)
  ratePerKm         Decimal? @db.Decimal(10, 4)
  ratePerLoad       Decimal? @db.Decimal(10, 2)
  revenuePercentage Decimal? @db.Decimal(5, 4)
  annualSalary      Decimal? @db.Decimal(12, 2)

  notes     String?
  createdBy String
  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([effectiveFrom])
  @@map("employee_pay_rates")
}

model EmployeeAwardClassification {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  effectiveFrom DateTime
  effectiveTo   DateTime?

  awardCode           AwardCode
  classificationLevel AwardClassificationLevel
  vehicleGrade        VehicleGrade?

  createdBy String
  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("employee_award_classifications")
}

model BankAccount {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  bsb           String  // encrypted
  accountNumber String  // encrypted
  accountName   String
  isPrimary     Boolean @default(false)

  // Split pay: allocationPercent OR allocationAmount, not both
  allocationPercent Decimal? @db.Decimal(5, 2)
  allocationAmount  Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("bank_accounts")
}

model EmergencyContact {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  name         String
  relationship String
  phone        String
  mobile       String?
  email        String?
  isPrimary    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("emergency_contacts")
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  documentType    DocumentType
  storageProvider StorageProvider @default(LOCAL)
  fileName        String
  fileKey         String // local path or S3 key
  fileSize        Int
  mimeType        String

  description String?
  expiryDate  DateTime?

  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@map("employee_documents")
}

// ═══════════════════════════════════════════════════════════════════
// ENTERPRISE AGREEMENTS
// ═══════════════════════════════════════════════════════════════════

model EnterpriseAgreement {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name             String
  fwoAeaNumber     String? // Fair Work AEA agreement number
  commencementDate DateTime  @db.Date
  expiryDate       DateTime? @db.Date
  documentKey      String? // S3 key for the EA document

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("enterprise_agreements")
}

// ═══════════════════════════════════════════════════════════════════
// PAYROLL
// ═══════════════════════════════════════════════════════════════════

model PayRun {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  payFrequency    PayFrequency
  periodStartDate DateTime     @db.Date
  periodEndDate   DateTime     @db.Date
  payDate         DateTime     @db.Date

  status PayRunStatus @default(DRAFT)

  // Superannuation rate locked at time of run — critical for historical accuracy
  sgRate Decimal @default(0.12) @db.Decimal(5, 4)

  // Calculated totals — denormalized for performance
  totalGross         Decimal @default(0) @db.Decimal(12, 2)
  totalTax           Decimal @default(0) @db.Decimal(12, 2)
  totalSuper         Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions    Decimal @default(0) @db.Decimal(12, 2)
  totalNet           Decimal @default(0) @db.Decimal(12, 2)
  totalEmployeeCount Int     @default(0)

  // ABA file output
  abaFileKey     String?
  abaGeneratedAt DateTime?

  // STP Phase 2
  stpEventId     String?
  stpSubmittedAt DateTime?
  stpStatus      STPStatus?

  notes       String?
  finalisedAt DateTime?
  finalisedBy String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PayRunItem[]

  @@index([companyId])
  @@index([periodStartDate, periodEndDate])
  @@index([status])
  @@map("pay_runs")
}

model PayRunItem {
  id         String   @id @default(cuid())
  payRunId   String
  payRun     PayRun   @relation(fields: [payRunId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  // Earnings breakdown (STP Phase 2 disaggregated reporting)
  ordinaryEarnings     Decimal @default(0) @db.Decimal(12, 2)
  overtimeEarnings     Decimal @default(0) @db.Decimal(12, 2)
  penaltyEarnings      Decimal @default(0) @db.Decimal(12, 2)
  allowancesTotal      Decimal @default(0) @db.Decimal(12, 2)
  nonTaxableAllowances Decimal @default(0) @db.Decimal(12, 2)
  leavePaidTotal       Decimal @default(0) @db.Decimal(12, 2)
  leavePaidLoading     Decimal @default(0) @db.Decimal(12, 2)
  grossEarnings        Decimal @default(0) @db.Decimal(12, 2)

  // Deductions
  preTaxDeductions  Decimal @default(0) @db.Decimal(12, 2)
  taxableIncome     Decimal @default(0) @db.Decimal(12, 2)
  paygWithholding   Decimal @default(0) @db.Decimal(12, 2)
  medicareLevy      Decimal @default(0) @db.Decimal(12, 2)
  postTaxDeductions Decimal @default(0) @db.Decimal(12, 2)

  // Superannuation
  superGuarantee Decimal @default(0) @db.Decimal(12, 2)
  voluntarySuper Decimal @default(0) @db.Decimal(12, 2)

  netPay Decimal @default(0) @db.Decimal(12, 2)

  // YTD balances as at this pay run (for STP reporting)
  ytdGross Decimal @default(0) @db.Decimal(12, 2)
  ytdTax   Decimal @default(0) @db.Decimal(12, 2)
  ytdSuper Decimal @default(0) @db.Decimal(12, 2)

  // Hours summary
  ordinaryHours Decimal @default(0) @db.Decimal(8, 2)
  overtimeHours Decimal @default(0) @db.Decimal(8, 2)

  // Payslip output
  payslipFileKey     String?
  payslipGeneratedAt DateTime?

  status PayRunItemStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  earnings   PayRunEarning[]
  allowances PayRunAllowanceItem[]
  deductions PayRunDeductionItem[]
  leaveItems PayRunLeaveItem[]

  @@unique([payRunId, employeeId])
  @@index([payRunId])
  @@index([employeeId])
  @@map("pay_run_items")
}

model PayRunEarning {
  id           String     @id @default(cuid())
  payRunItemId String
  payRunItem   PayRunItem @relation(fields: [payRunItemId], references: [id])

  earningType EarningType
  description String
  hours       Decimal? @db.Decimal(8, 2)
  rate        Decimal? @db.Decimal(10, 4)
  units       Decimal? @db.Decimal(10, 3)
  amount      Decimal  @db.Decimal(12, 2)

  @@index([payRunItemId])
  @@map("pay_run_earnings")
}

model AllowanceType {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code        String
  name        String
  description String?

  isTaxable   Boolean @default(true)
  stpCategory String?

  defaultAmount Decimal? @db.Decimal(10, 2)
  isPerDiem     Boolean  @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payRunAllowances PayRunAllowanceItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("allowance_types")
}

model PayRunAllowanceItem {
  id              String        @id @default(cuid())
  payRunItemId    String
  payRunItem      PayRunItem    @relation(fields: [payRunItemId], references: [id])
  allowanceTypeId String
  allowanceType   AllowanceType @relation(fields: [allowanceTypeId], references: [id])

  units  Decimal? @db.Decimal(10, 3)
  amount Decimal  @db.Decimal(12, 2)

  @@index([payRunItemId])
  @@map("pay_run_allowance_items")
}

model DeductionType {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code        String
  name        String
  description String?

  isPreTax    Boolean @default(false)
  stpCategory String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payRunDeductions PayRunDeductionItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("deduction_types")
}

model PayRunDeductionItem {
  id              String        @id @default(cuid())
  payRunItemId    String
  payRunItem      PayRunItem    @relation(fields: [payRunItemId], references: [id])
  deductionTypeId String
  deductionType   DeductionType @relation(fields: [deductionTypeId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  @@index([payRunItemId])
  @@map("pay_run_deduction_items")
}

model PayRunLeaveItem {
  id             String        @id @default(cuid())
  payRunItemId   String
  payRunItem     PayRunItem    @relation(fields: [payRunItemId], references: [id])
  leaveRequestId String?
  leaveRequest   LeaveRequest? @relation(fields: [leaveRequestId], references: [id])

  leaveType     LeaveType
  hours         Decimal @db.Decimal(8, 2)
  amount        Decimal @db.Decimal(12, 2)
  loadingAmount Decimal @default(0) @db.Decimal(12, 2)

  @@index([payRunItemId])
  @@map("pay_run_leave_items")
}

// ═══════════════════════════════════════════════════════════════════
// AWARD RATE CONFIGURATION
// All rates stored with effective dates — historical calculations
// must use the rate that was current at the time of the pay run.
// Verify all figures against the Fair Work Ombudsman and ATO
// official sources before seeding.
// ═══════════════════════════════════════════════════════════════════

model AwardBaseRate {
  id                  String                   @id @default(cuid())
  award               AwardCode
  classificationLevel AwardClassificationLevel
  vehicleGrade        VehicleGrade?

  weeklyRate Decimal @db.Decimal(10, 4) // ordinary-time weekly rate
  hourlyRate Decimal @db.Decimal(10, 4) // weeklyRate / 38

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  source    String? // e.g. "FWC Annual Wage Review 2025"
  createdAt DateTime @default(now())

  @@unique([award, classificationLevel, vehicleGrade, effectiveFrom])
  @@index([award, classificationLevel])
  @@index([effectiveFrom])
  @@map("award_base_rates")
}

model AwardAllowanceRate {
  id    String     @id @default(cuid())
  award AwardCode? // null = applies to both awards

  code        String // e.g. "TRUCK_ALLOWANCE", "MEAL_ALLOWANCE"
  name        String
  description String?

  rateType    AllowanceRateType
  amount      Decimal           @db.Decimal(10, 4)
  isTaxable   Boolean           @default(true)
  stpCategory String? // STP Phase 2 category code

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  source    String?
  createdAt DateTime @default(now())

  @@unique([code, effectiveFrom])
  @@index([award])
  @@index([effectiveFrom])
  @@map("award_allowance_rates")
}

model AwardPenaltyRate {
  id          String          @id @default(cuid())
  award       AwardCode
  penaltyType PenaltyRateType
  multiplier  Decimal         @db.Decimal(5, 4) // e.g. 1.5000 = time-and-a-half

  // null = applies to all classification levels for this award
  classificationLevel AwardClassificationLevel?

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  source    String?
  createdAt DateTime @default(now())

  @@unique([award, penaltyType, classificationLevel, effectiveFrom])
  @@index([award, penaltyType])
  @@index([effectiveFrom])
  @@map("award_penalty_rates")
}

// ═══════════════════════════════════════════════════════════════════
// TAX CONFIGURATION
// Verify all figures against ATO NAT 3539 (Statement of Formulas)
// and NAT 1008 (weekly tax tables) before seeding each financial year.
// ═══════════════════════════════════════════════════════════════════

model PaygTaxBracket {
  id String @id @default(cuid())

  financialYear          String             // e.g. "2025-26"
  taxResidencyStatus     TaxResidencyStatus
  claimsTaxFreeThreshold Boolean
  hasHECS                Boolean            @default(false)
  payFrequency           PayFrequency

  // Annual income bracket — for withholding formula (NAT 3539)
  annualEarningsFrom Decimal  @db.Decimal(10, 2)
  annualEarningsTo   Decimal? @db.Decimal(10, 2) // null = no upper limit

  // ATO withholding formula coefficients: withholding = (a × annualised) - b
  // Coefficients from NAT 3539 column a and b
  coefficientA Decimal @db.Decimal(14, 7)
  coefficientB Decimal @db.Decimal(14, 7)

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  source    String?
  createdAt DateTime @default(now())

  @@index([financialYear, taxResidencyStatus, claimsTaxFreeThreshold, hasHECS, payFrequency])
  @@index([effectiveFrom])
  @@map("payg_tax_brackets")
}

model SuperannuationRate {
  id            String @id @default(cuid())
  financialYear String // e.g. "2025-26"

  rate           Decimal @db.Decimal(5, 4) // e.g. 0.1200 = 12%
  effectiveFrom  DateTime @db.Date
  effectiveTo    DateTime? @db.Date

  // Maximum super contribution base (quarterly) — ATO published
  maxContributionBaseQuarterly Decimal? @db.Decimal(12, 2)

  source    String?
  createdAt DateTime @default(now())

  @@unique([effectiveFrom])
  @@index([effectiveFrom])
  @@map("superannuation_rates")
}

// ═══════════════════════════════════════════════════════════════════
// TIME AND ATTENDANCE
// ═══════════════════════════════════════════════════════════════════

model Timesheet {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  weekStartDate DateTime @db.Date
  weekEndDate   DateTime @db.Date

  status TimesheetStatus @default(DRAFT)

  totalOrdinaryHours Decimal @default(0) @db.Decimal(8, 2)
  totalOvertimeHours Decimal @default(0) @db.Decimal(8, 2)
  totalHours         Decimal @default(0) @db.Decimal(8, 2)

  submittedAt DateTime?
  submittedBy String?

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  approvedBy String?
  approvedAt DateTime?

  payRunItemId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries TimesheetEntry[]

  @@unique([employeeId, weekStartDate])
  @@index([employeeId])
  @@index([weekStartDate])
  @@index([status])
  @@map("timesheets")
}

model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])

  entryDate DateTime @db.Date

  clockIn  DateTime?
  clockOut DateTime?

  // GPS capture for mobile clock-in
  clockInLat  Decimal? @db.Decimal(10, 7)
  clockInLng  Decimal? @db.Decimal(10, 7)
  clockOutLat Decimal? @db.Decimal(10, 7)
  clockOutLng Decimal? @db.Decimal(10, 7)

  ordinaryHours Decimal @default(0) @db.Decimal(8, 2)
  overtimeHours Decimal @default(0) @db.Decimal(8, 2)
  totalHours    Decimal @default(0) @db.Decimal(8, 2)

  costCentre    String?
  depotId       String?
  notes         String?
  isManualEntry Boolean @default(false)

  breaks TimesheetBreak[]

  @@index([timesheetId])
  @@index([entryDate])
  @@map("timesheet_entries")
}

model TimesheetBreak {
  id      String         @id @default(cuid())
  entryId String
  entry   TimesheetEntry @relation(fields: [entryId], references: [id])

