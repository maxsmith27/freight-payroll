model ShiftTemplate {
  id        String  @id @default(cuid())
  companyId String
  depotId   String?

  name       String
  startTime  String // HH:MM
  endTime    String // HH:MM
  daysOfWeek Int[]  // 0=Sunday … 6=Saturday

  runCode     String?
  vehicleType String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("shift_templates")
}

model EmployeeAvailability {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  fromDate DateTime @db.Date
  toDate   DateTime @db.Date

  availabilityType AvailabilityType
  reason           String?

  status     AvailabilityStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([fromDate, toDate])
  @@map("employee_availabilities")
}

// ═══════════════════════════════════════════════════════════════════
// VEHICLES AND FLEET
// ═══════════════════════════════════════════════════════════════════

model Vehicle {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  rego         String
  regoState    AustralianState
  make         String?
  model        String?
  year         Int?
  vehicleGrade VehicleGrade?
  colour       String?

  // Physical specs
  grossVehicleMass Int? // kg
  tare             Int? // kg (unladen weight)

  // Registration and compliance
  regoExpiry      DateTime? @db.Date
  nextServiceDate DateTime? @db.Date

  // Insurance
  insurancePolicyNumber String?
  insuranceExpiry       DateTime? @db.Date

  // Telematics
  gpsDeviceId String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceRecords VehicleServiceRecord[]
  incidents      VehicleIncident[]
  rosterShifts   RosterShift[]

  @@unique([companyId, rego])
  @@index([companyId])
  @@map("vehicles")
}

model VehicleServiceRecord {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  serviceDate  DateTime @db.Date
  serviceType  String // e.g. "Annual Service", "RMS Inspection", "Tyre Replacement"
  odometerKm   Int?
  costCents    Int? // in cents to avoid decimal issues
  providerName String?
  notes        String?
  documentKey  String? // S3 key for service invoice

  nextServiceDate DateTime? @db.Date
  nextServiceOdoKm Int?

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([serviceDate])
  @@map("vehicle_service_records")
}

model VehicleIncident {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  incidentDate DateTime
  incidentType String // ACCIDENT, NEAR_MISS, BREAKDOWN, THEFT, DAMAGE

  description            String
  driverEmployeeId       String?
  location               String?
  policeReportNumber     String?
  insuranceClaimNumber   String?
  estimatedDamageCents   Int?
  documentKeys           String[] // S3 keys for photos/reports

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([incidentDate])
  @@map("vehicle_incidents")
}

// ═══════════════════════════════════════════════════════════════════
// SUBCONTRACTORS (Owner-Drivers)
// ═══════════════════════════════════════════════════════════════════

model Subcontractor {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  entityType SubcontractorEntityType

  // Individual fields
  firstName String?
  lastName  String?

  // Company/trust fields
  businessName String?
  tradingName  String?

  abn String

  // Contact
  email  String?
  phone  String?
  mobile String?

  // Address
  addressStreet   String?
  addressSuburb   String?
  addressState    AustralianState?
  addressPostcode String?

  // Payment bank account (encrypted)
  bankBsb     String? // encrypted
  bankAccount String? // encrypted
  bankName    String?

  // Voluntary PAYG withholding (if they elect to have tax withheld)
  voluntaryWithholdingRate Decimal? @db.Decimal(5, 4)

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  contracts SubcontractorContract[]
  vehicles  SubcontractorVehicle[]
  payments  SubcontractorPayment[]

  @@unique([companyId, abn])
  @@index([companyId])
  @@map("subcontractors")
}

model SubcontractorContract {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id])

  contractType    SubcontractorContractType
  ratePerKm       Decimal? @db.Decimal(10, 4)
  ratePerLoad     Decimal? @db.Decimal(10, 2)
  fixedWeeklyRate Decimal? @db.Decimal(12, 2)

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  documentKey   String? // S3 key for signed contract

  createdAt DateTime @default(now())

  @@index([subcontractorId])
  @@index([effectiveFrom])
  @@map("subcontractor_contracts")
}

model SubcontractorVehicle {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id])

  rego         String
  regoState    AustralianState
  make         String?
  model        String?
  year         Int?
  vehicleGrade VehicleGrade?

  createdAt DateTime @default(now())

  @@index([subcontractorId])
  @@map("subcontractor_vehicles")
}

model SubcontractorPayment {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id])
  companyId       String

  periodStartDate DateTime @db.Date
  periodEndDate   DateTime @db.Date
  paymentDate     DateTime @db.Date

  // Totals
  totalKilometres Decimal? @db.Decimal(10, 2)
  totalLoads      Int?

  subtotal       Decimal @db.Decimal(12, 2)
  withholdingTax Decimal @default(0) @db.Decimal(12, 2)
  gst            Decimal @default(0) @db.Decimal(12, 2)
  netPayment     Decimal @db.Decimal(12, 2)

  status        SubcontractorPaymentStatus @default(DRAFT)
  invoiceNumber String?
  abaFileKey    String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines SubcontractorPaymentLine[]

  @@index([subcontractorId])
  @@index([companyId])
  @@index([periodStartDate])
  @@map("subcontractor_payments")
}

model SubcontractorPaymentLine {
  id        String               @id @default(cuid())
  paymentId String
  payment   SubcontractorPayment @relation(fields: [paymentId], references: [id])

  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unitRate    Decimal  @db.Decimal(10, 4)
  amount      Decimal  @db.Decimal(12, 2)
  runDate     DateTime? @db.Date
  runCode     String?

  @@index([paymentId])
  @@map("subcontractor_payment_lines")
}

// ═══════════════════════════════════════════════════════════════════
// WORKPLACE SAFETY
// ═══════════════════════════════════════════════════════════════════

model WorkplaceIncident {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  incidentDate     DateTime
  incidentType     IncidentType
  description      String
  location         String?

  involvedEmployeeId String?
  involvedEmployee   Employee? @relation("IncidentInvolvedEmployee", fields: [involvedEmployeeId], references: [id])

  injuryDescription  String?
  treatmentProvided  String?
  lostTimeInjury     Boolean   @default(false)
  returnToWorkDate   DateTime? @db.Date

  // Regulatory notifications
  reportedToSafeworkAt DateTime?
  safeworkRefNumber    String?
  notifiableIncident   Boolean @default(false)

  documentKeys String[] // S3 keys for incident photos, forms

  workersCompClaimId String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([incidentDate])
  @@map("workplace_incidents")
}

model WorkersCompClaim {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  companyId  String

  claimNumber String?
  insurer     String?

  injuryDate DateTime @db.Date
  injuryType String
  bodyPart   String?

  status ClaimStatus @default(OPEN)

  // Return to work
  rtpDate              DateTime? @db.Date // return to pre-injury duties date
  weeklyBenefitCents   Int?

  documentKeys String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([companyId])
  @@map("workers_comp_claims")
}

// ═══════════════════════════════════════════════════════════════════
// COMPLIANCE (Licences, Accreditations, Fatigue, Training)
// ═══════════════════════════════════════════════════════════════════

model DriverLicence {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  licenceNumber  String
  licenceState   AustralianState
  licenceClasses LicenceClass[]

  issueDate  DateTime @db.Date
  expiryDate DateTime @db.Date

  restrictions String?
  documentKey  String? // S3 key

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([expiryDate])
  @@map("driver_licences")
}

model Accreditation {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  accreditationType AccreditationType
  certificateNumber String?

  issueDate  DateTime  @db.Date
  expiryDate DateTime? @db.Date

  issuingBody String?
  documentKey String? // S3 key

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([expiryDate])
  @@map("accreditations")
}

model MedicalCertificate {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  certType      MedicalCertType
  issuingDoctor String?

  issueDate  DateTime @db.Date
  expiryDate DateTime @db.Date

  restrictions String?
  documentKey  String? // S3 key

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([expiryDate])
  @@map("medical_certificates")
}

model FatigueRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  recordDate DateTime @db.Date

  workStartTime DateTime
  workEndTime   DateTime?
  workMinutes   Int?

  restStartTime DateTime?
  restEndTime   DateTime?
  restMinutes   Int?

  locationStart String?
  locationEnd   String?

  fatigueScheme FatigueScheme @default(STANDARD_HOURS)

  isCompliant   Boolean @default(true)
  violationType String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([recordDate])
  @@map("fatigue_records")
}

model TrainingRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  trainingName  String
  trainingType  String?
  completedDate DateTime  @db.Date
  expiryDate    DateTime? @db.Date
  documentKey   String? // S3 key

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("training_records")
}

// ═══════════════════════════════════════════════════════════════════
// SAAS SUBSCRIPTION
// ═══════════════════════════════════════════════════════════════════

model SubscriptionPlan {
  id   String @id @default(cuid())
  code String @unique // STARTER, GROWTH, ENTERPRISE

  name             String
  maxEmployees     Int? // null = unlimited
  maxCompanies     Int?
  maxDepots        Int?

  // Feature gates
  hasApiAccess        Boolean @default(false)
  hasWebhooks         Boolean @default(false)
  hasSso              Boolean @default(false)
  hasWhiteLabel       Boolean @default(false)
  hasAdvancedReports  Boolean @default(false)
  hasSubcontractors   Boolean @default(true)

  monthlyPriceCents Int // AUD cents
  annualPriceCents  Int // total annual price in AUD cents

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions OrganizationSubscription[]

  @@map("subscription_plans")
}

model OrganizationSubscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  organization   Organization       @relation(fields: [organizationId], references: [id])
  planId         String
  plan           SubscriptionPlan   @relation(fields: [planId], references: [id])

  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle       @default(MONTHLY)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?

  // Payment processor IDs (Stripe)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("organization_subscriptions")
}

// ═══════════════════════════════════════════════════════════════════
// INTEGRATIONS (Xero, MYOB, Deputy, etc.)
// ═══════════════════════════════════════════════════════════════════

model IntegrationToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  provider     IntegrationProvider
  accessToken  String // encrypted
  refreshToken String? // encrypted
  scope        String?
  expiresAt    DateTime?

  // Provider-specific metadata
  tenantId   String? // Xero tenant ID
  tenantName String? // Xero org name

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@map("integration_tokens")
}

model IntegrationMapping {
  id             String  @id @default(cuid())
  organizationId String
  companyId      String?

  provider     IntegrationProvider
  mappingType  String // e.g. "PAYG_ACCOUNT", "SUPER_LIABILITY", "WAGES_EXPENSE"
  localId      String // our ID or code
  externalId   String // their account/object ID
  externalName String? // human-readable label from their system

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider, mappingType, localId])
  @@index([organizationId, provider])
  @@map("integration_mappings")
}

// ═══════════════════════════════════════════════════════════════════
// API KEYS AND WEBHOOKS
// ═══════════════════════════════════════════════════════════════════

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name      String
  keyHash   String   @unique // SHA-256 of the full key — never store raw
  keyPrefix String   // first 12 chars for display, e.g. "fpk_live_abc1"

  scopes String[] // e.g. ["employees:read", "payroll:read"]

  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdBy String
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([keyHash])
  @@map("api_keys")
}

model WebhookEndpoint {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  url    String
  secret String // HMAC-SHA256 signing secret (encrypted at rest)

  events String[] // e.g. ["pay_run.finalised", "employee.created"]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id])

  event   String
  payload Json

  statusCode   Int?
  responseBody String? // truncated to 2000 chars

  attemptCount Int       @default(0)
  succeededAt  DateTime?
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())

  @@index([endpointId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// ═══════════════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════════════

model AuditLog {
  id String @id @default(cuid())

  organizationId String?
  companyId      String?

  userId     String?
  employeeId String?
  employee   Employee? @relation("EmployeeAuditLogs", fields: [employeeId], references: [id])

  action     AuditAction
  entityType String
  entityId   String

  previousValues Json?
  newValues      Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════
// SYSTEM CONFIGURATION
// ═══════════════════════════════════════════════════════════════════

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

