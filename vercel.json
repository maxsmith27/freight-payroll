{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @freight-payroll/backend exec prisma generate",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
